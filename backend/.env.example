# ChildFit 环境配置示例

# 应用配置
APP_NAME=ChildFit
APP_VERSION=2.0.0
DEBUG=True

# 数据库配置
DATABASE_URL=mysql+pymysql://childfit:ChildFit%402026@localhost:3306/childfit

# Redis 配置
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=childfit

# JWT 配置 (生产环境请修改!)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS 配置
ALLOWED_ORIGINS=["*"]

# 天气 API 配置 (和风天气)
HEFENG_API_KEY=your-hefeng-api-key
HEFENG_BASE_URL=https://devapi.qweather.com/v7

# 腾讯云 COS 配置 (可选)
COS_BUCKET=
COS_REGION=ap-guangzhou
COS_SECRET_ID=
COS_SECRET_KEY=

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=./logs
